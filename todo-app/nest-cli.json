{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "plugins": ["@nestjs/swagger"],
    "typeCheck": true,
    "builder": {
      "type": "swc",
      "options": {
        "ignore": [
          "src/todo/dto/todo-response.dto.js",
          "src/todo/entities/todo.entity.js"
        ]
      }
    }
  }
}
